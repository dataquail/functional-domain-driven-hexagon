{
  "extends": "../../tsconfig.base.json",
  "include": ["src/**/*.test.ts"],
  "references": [
    { "path": "tsconfig.src.json" },
    { "path": "../contracts" },
    { "path": "../database" }
  ],
  "compilerOptions": {
    "types": ["node"],
    "tsBuildInfoFile": ".tsbuildinfo/test.tsbuildinfo",
    "rootDir": ".",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@org/contracts": ["../contracts/src/index.js"],
      "@org/contracts/*": ["../contracts/src/*.js"],
      "@org/database": ["../database/src/index.js"],
      "@org/database/*": ["../database/src/*.js"]
    }
  }
}
