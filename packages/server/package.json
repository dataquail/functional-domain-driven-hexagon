{
  "name": "@org/server",
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "description": "The server template",
  "repository": {
    "type": "git",
    "url": "https://github.com/lucas-barake/effect-monorepo.git",
    "directory": "packages/server"
  },
  "scripts": {
    "check": "tsc -b tsconfig.json",
    "test": "vitest",
    "coverage": "vitest --coverage",
    "clean": "rm -rf build .tsbuildinfo",
    "prebuild": "npm run clean",
    "build": "tsc -b tsconfig.build.json",
    "predev": "lsof -ti:3001 | xargs kill -9 2>/dev/null; true",
    "dev": "TSX_TSCONFIG_PATH=./tsconfig.src.json tsx watch src/server.ts",
    "start": "node build/esm/server.js",
    "circular": "madge --circular src/server.ts",
    "lint": "eslint . --quiet",
    "format": "prettier --write .",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@aws-sdk/client-sesv2": "^3.1081.0",
    "@effect/platform-node": "4.0.0-beta.94",
    "@org/contracts": "workspace:^",
    "@org/database": "workspace:^",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.10",
    "cookie": "^1.1.1",
    "effect": "4.0.0-beta.94",
    "nodemailer": "^9.0.3",
    "openid-client": "^6.8.4",
    "pg": "8.13.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^22.3.0",
    "svix": "^1.96.1"
  },
  "effect": {
    "generateExports": {
      "include": [
        "**/*.ts"
      ]
    },
    "generateIndex": {
      "include": [
        "**/*.ts"
      ]
    }
  },
  "devDependencies": {
    "@types/cookie": "^0.6.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^16.6.1",
    "madge": "^8.0.0",
    "tsx": "^4.23.0"
  }
}
