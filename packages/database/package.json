{
  "name": "@org/database",
  "version": "0.0.0",
  "type": "module",
  "license": "MIT",
  "description": "The database template",
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lucas-barake/effect-monorepo.git",
    "directory": "packages/database"
  },
  "scripts": {
    "codegen": "build-utils prepare-v2",
    "build": "tsc -b tsconfig.build.json",
    "build-esm": "tsc -b tsconfig.build.json",
    "build-cjs": "babel build/esm --plugins @babel/transform-export-namespace-from --plugins @babel/transform-modules-commonjs --out-dir build/cjs --source-maps",
    "build-annotate": "babel build/esm --plugins annotate-pure-calls --out-dir build/esm --source-maps",
    "check": "tsc -b tsconfig.json",
    "test": "vitest",
    "coverage": "vitest --coverage",
    "db:migrate": "docker compose --profile migrate run --rm flyway",
    "db:migrate:test": "docker compose --profile migrate-test run --rm flyway-test",
    "db:reset": "tsx ./src/scripts/reset-database.ts"
  },
  "dependencies": {
    "@effect/platform": "0.96.2",
    "@effect/platform-node": "0.107.0",
    "@standard-schema/spec": "^1.1.0",
    "effect": "3.21.4",
    "pg": "8.13.1",
    "slonik": "^48.19.0"
  },
  "effect": {
    "generateExports": {
      "include": [
        "**/*.ts"
      ]
    },
    "generateIndex": {
      "include": [
        "**/*.ts"
      ]
    }
  },
  "devDependencies": {
    "@types/dotenv": "^8.2.3",
    "@types/pg": "^8.20.0",
    "dotenv": "^16.6.1",
    "tsx": "^4.23.0"
  }
}
