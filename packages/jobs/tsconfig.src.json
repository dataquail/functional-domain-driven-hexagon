{
  "extends": "../../tsconfig.base.json",
  "include": ["src"],
  "exclude": ["vitest.config.ts", "src/**/*.test.ts"],
  "references": [{ "path": "../database" }],
  "compilerOptions": {
    "types": ["node"],
    "outDir": "build/src",
    "tsBuildInfoFile": ".tsbuildinfo/src.tsbuildinfo",
    "rootDir": "src",

    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@org/database": ["../database/src/index.js"],
      "@org/database/*": ["../database/src/*.js"]
    }
  }
}
