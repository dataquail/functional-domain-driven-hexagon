    "@org/components": "workspace:^",
    "@org/contracts": "workspace:^",
    "@tanstack/react-form": "^0.43.2",
    "@tanstack/react-query": "5.100.6",
    "@tanstack/react-query-devtools": "^5.100.6",
    "@vercel/otel": "^2.0.0",
    "effect": "*",
    "mutative": "^1.1.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
