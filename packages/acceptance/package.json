{
  "name": "@org/acceptance",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Playwright acceptance tests with layered architecture (specs / drivers / pages / infrastructure). See ADR / docs/scratch/template-evaluation-remediation-plan.md.",
  "scripts": {
    "test": "pnpm -F @org/web build && playwright test",
    "test:ui": "pnpm -F @org/web build && playwright test --ui",
    "check": "tsc --noEmit"
  },
  "devDependencies": {
    "@org/contracts": "workspace:^",
    "@org/test-drivers": "workspace:^",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.11.10",
    "@effect/platform": "*",
    "dotenv": "^16.4.7",
    "effect": "^3.20.0",
    "pg": "8.13.1",
    "typescript": "~5.7.2"
  }
}
