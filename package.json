{
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.3.0",
  "engines": {
    "node": "22.13.1",
    "pnpm": "10.3.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lucas-barake/effect-monorepo.git"
  },
  "scripts": {
    "codegen": "pnpm --recursive --parallel run codegen",
    "build": "tsc -b tsconfig.build.json && pnpm --recursive --parallel run build",
    "check": "tsc -b tsconfig.json",
    "check:recursive": "pnpm --recursive exec tsc -b tsconfig.json",
    "check:all": "pnpm lint && pnpm lint:deps && pnpm lint:tests && pnpm check && pnpm test && pnpm -F @org/components build-storybook",
    "lint": "eslint \"**/{src,test,examples,dtslint}/**/*.{ts,mjs,tsx}\" \"packages/web/{app,features,lib,services}/**/*.{ts,tsx}\" \"packages/web/{instrumentation,next.config}.ts\" \"packages/components/{primitives,patterns,providers,lib}/**/*.{ts,tsx}\" \"packages/components/.storybook/**/*.{ts,tsx}\" \"packages/acceptance/{specs,drivers,test-utils,setup}/**/*.{ts,tsx}\" \"packages/acceptance/{playwright.config,global-setup}.ts\" --quiet",
    "lint:fix": "pnpm lint --fix",
    "lint:deps": "depcruise --config .dependency-cruiser.cjs packages/server/src packages/contracts/src packages/jobs/src && depcruise --config .dependency-cruiser.cjs --ts-config tsconfig.depcruise-web.json packages/web packages/components",
    "lint:tests": "node scripts/check-test-parity.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:acceptance": "pnpm -F @org/acceptance test",
    "bootstrap": "node scripts/dev-bootstrap.mjs",
    "auth:up": "docker compose up -d zitadel",
    "auth:seed": "docker compose --profile seed-zitadel up --abort-on-container-exit seed-zitadel",
    "auth:down": "docker compose stop zitadel",
    "auth:logs": "docker compose logs -f zitadel",
    "auth:reset": "node scripts/auth-reset.mjs",
    "jobs:dev": "pnpm -F @org/jobs dev",
    "format": "prettier --write \"**/*.{js,ts,mjs,jsx,tsx,json,md,css,html,yaml,yml,mdx}\"",
    "format:check": "prettier --check \"**/*.{js,ts,mjs,jsx,tsx,json,md,css,html,yaml,yml,mdx}\"",
    "coverage": "vitest --coverage",
    "prepare": "husky"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-export-namespace-from": "^7.27.1",
    "@babel/plugin-transform-modules-commonjs": "^7.25.9",
    "@effect/build-utils": "0.8.9",
    "@effect/eslint-plugin": "0.3.2",
    "@effect/language-service": "0.85.1",
    "@effect/vitest": "0.29.0",
    "@eslint/compat": "1.2.2",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.13.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "8.59.1",
    "@typescript-eslint/parser": "8.59.1",
    "babel-plugin-annotate-pure-calls": "^0.4.0",
    "dependency-cruiser": "^17.3.10",
    "effect": "3.21.2",
    "eslint": "9.13.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-codegen": "^0.34.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-sort-destructure-keys": "^3.0.0",
    "eslint-plugin-storybook": "^10.3.6",
    "glob": "^11.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "3.8.3",
    "prettier-plugin-organize-imports": "4.3.0",
    "prettier-plugin-tailwindcss": "0.8.0",
    "read-package-up": "^12.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "vitest": "^4.1.5",
      "effect": "3.21.2",
      "@effect/rpc": "0.75.1",
      "@effect/platform": "0.96.1",
      "@effect/platform-browser": "0.76.0",
      "@effect/experimental": "0.60.0",
      "@effect/opentelemetry": "0.63.0",
      "@effect/platform-node": "0.106.0",
      "@effect/cluster": "0.58.2",
      "@effect/sql": "0.51.1",
      "@effect/workflow": "0.18.1",
      "@effect/build-utils": "0.8.9",
      "@effect/eslint-plugin": "0.3.2",
      "@effect/language-service": "0.85.1",
      "@effect/vitest": "0.29.0",
      "@opentelemetry/resources": "2.7.1",
      "@opentelemetry/sdk-trace-web": "2.7.1",
      "protobufjs": "^7.5.5",
      "form-data": "^4.0.4",
      "flatted": "^3.4.2",
      "rollup": "^4.60.0",
      "lodash": "^4.18.1",
      "glob@10": "^10.5.0",
      "glob@11": "^11.1.0",
      "uuid": "^14.0.0",
      "js-yaml@3": "^3.14.2",
      "@babel/runtime": "^7.26.10",
      "esbuild": "^0.25.0",
      "picomatch@4": "^4.0.4",
      "minimatch@9": "^9.0.7"
    },
    "patchedDependencies": {
      "babel-plugin-annotate-pure-calls@0.4.0": "patches/babel-plugin-annotate-pure-calls@0.4.0.patch"
    }
  }
}
