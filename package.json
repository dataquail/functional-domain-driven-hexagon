{
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.3.0",
  "engines": {
    "node": "22.14.0",
    "pnpm": "10.3.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lucas-barake/effect-monorepo.git"
  },
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "codegen": "pnpm --recursive --parallel run codegen",
    "build": "tsc -b tsconfig.build.json && pnpm --recursive --parallel run build",
    "check": "tsc -b tsconfig.json",
    "check:recursive": "pnpm --recursive exec tsc -b tsconfig.json",
    "check:all": "pnpm lint && pnpm lint:deps && pnpm lint:tests && pnpm check && pnpm test && pnpm build:storybook",
    "build:storybook": "pnpm -F @org/client build-storybook --quiet",
    "lint": "eslint \"**/{src,test,examples,scripts,dtslint}/**/*.{ts,mjs,tsx}\" \"packages/acceptance/{specs,drivers,test-utils}/**/*.{ts,tsx}\" \"packages/acceptance/{playwright.config,global-setup}.ts\" --quiet",
    "lint:fix": "pnpm lint --fix",
    "lint:deps": "depcruise --config .dependency-cruiser.cjs packages/server/src packages/contracts/src && depcruise --config .dependency-cruiser.cjs --ts-config tsconfig.depcruise-client.json packages/client/src",
    "lint:tests": "node scripts/check-test-parity.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:acceptance": "pnpm -F @org/acceptance test",
    "format": "prettier --write \"**/*.{js,ts,mjs,jsx,tsx,json,md,css,html,yaml,yml,mdx}\"",
    "format:check": "prettier --check \"**/*.{js,ts,mjs,jsx,tsx,json,md,css,html,yaml,yml,mdx}\"",
    "coverage": "vitest --coverage",
    "prepare": "husky"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.26.0",
    "@babel/plugin-transform-export-namespace-from": "^7.27.1",
    "@babel/plugin-transform-modules-commonjs": "^7.25.9",
    "@effect/build-utils": "0.8.9",
    "@effect/eslint-plugin": "0.3.2",
    "@effect/language-service": "0.85.1",
    "@effect/vitest": "0.29.0",
    "@eslint/compat": "1.2.2",
    "@eslint/eslintrc": "3.1.0",
    "@eslint/js": "9.13.0",
    "@types/node": "^22.8.5",
    "@typescript-eslint/eslint-plugin": "8.14.0",
    "@typescript-eslint/parser": "8.14.0",
    "babel-plugin-annotate-pure-calls": "^0.4.0",
    "dependency-cruiser": "^17.3.10",
    "effect": "3.21.2",
    "eslint": "9.13.0",
    "eslint-import-resolver-typescript": "^3.6.3",
    "eslint-plugin-codegen": "^0.29.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sort-destructure-keys": "^2.0.0",
    "eslint-plugin-storybook": "^10.3.6",
    "glob": "^11.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "3.8.3",
    "prettier-plugin-organize-imports": "4.3.0",
    "prettier-plugin-tailwindcss": "0.8.0",
    "read-package-up": "^11.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "pnpm": {
    "overrides": {
      "vitest": "^2.0.5",
      "effect": "3.21.2",
      "@effect/rpc": "0.56.6",
      "@effect/platform": "0.80.16",
      "@effect/platform-browser": "0.60.9",
      "@effect/experimental": "0.44.16",
      "@effect/opentelemetry": "0.45.6",
      "@effect/platform-node": "0.77.4",
      "@effect/cluster": "0.30.4",
      "@effect/sql": "0.33.16",
      "@effect/build-utils": "0.8.9",
      "@effect/eslint-plugin": "0.3.2",
      "@effect/language-service": "0.85.1",
      "@effect/vitest": "0.29.0"
    },
    "patchedDependencies": {
      "babel-plugin-annotate-pure-calls@0.4.0": "patches/babel-plugin-annotate-pure-calls@0.4.0.patch"
    }
  }
}
