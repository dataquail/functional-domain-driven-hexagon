# Web (browser-exposed; Next inlines NEXT_PUBLIC_* into the client bundle)
# Browser → Jaeger OTLP/HTTP. CORS for http://localhost:* is enabled in
# infra/jaeger/config.yaml. Falls back to this default if unset.
NEXT_PUBLIC_OTLP_URL=http://localhost:4318/v1/traces

# Server
ENV=dev # dev, prod, staging
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/effect-monorepo
# Test DB — create with: psql -h localhost -U postgres -c 'CREATE DATABASE "effect-monorepo-test"'
DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:5432/effect-monorepo-test
OTLP_URL=http://localhost:4318/v1/traces
PORT=3001
# Browser-facing origin. BFF redirects here after sign-in; session cookie
# scopes here. ADR-0018.
APP_URL=http://localhost:3000

# Internal URL for Next.js → Effect server proxy. Next's rewrites() forward
# /api/* to this URL with the inbound Cookie header attached. See ADR-0018.
SERVER_INTERNAL_URL=http://localhost:3001

# Zitadel (self-hosted via docker-compose; see infra/zitadel/)
ZITADEL_ISSUER=http://localhost:8080
ZITADEL_ADMIN_EMAIL=admin@example.com
ZITADEL_ADMIN_PASSWORD=ChangeMe!1
ZITADEL_REDIRECT_URI=http://localhost:3000/api/auth/callback
ZITADEL_POST_LOGOUT_REDIRECT_URI=http://localhost:3000/
# Zitadel-registered redirect URIs. Comma-separated to support sibling
# origins (preview deployments, marketing site, etc.). Default reflects
# the single Next-fronted browser origin.
APP_REDIRECT_URI=http://localhost:3000/api/auth/callback
APP_POST_LOGOUT_REDIRECT_URI=http://localhost:3000/
# One-time bootstrap PAT — see error message from `pnpm auth:seed` for setup steps
ZITADEL_BOOTSTRAP_PAT=
# Filled in by `pnpm auth:seed` (paste from its stdout into this file, then restart the server)
ZITADEL_CLIENT_ID=
ZITADEL_CLIENT_SECRET=
# 32+ chars for the dev compose; rotate before any prod deploy
ZITADEL_MASTERKEY=MasterkeyNeedsToHave32Characters

# SMTP (Zitadel notification provider — configured idempotently by `pnpm auth:seed`)
# Local dev uses the Mailpit container; web UI at http://localhost:8025.
# For other environments, point these at your real provider (SES, SendGrid, …).
# SMTP_DESCRIPTION is the idempotency key — keep it stable across envs.
SMTP_HOST=mailpit
SMTP_PORT=1025
# Zitadel v2.71 requires a non-empty user/password (its notification subsystem
# rejects nil-encrypted-password configs). Mailpit ignores SMTP AUTH, so any
# placeholder works locally; replace with real provider credentials in prod.
SMTP_USER=dev
SMTP_PASSWORD=dev
SMTP_TLS=false
SMTP_FROM_ADDRESS=noreply@localhost
SMTP_FROM_NAME=Effect Monorepo
SMTP_REPLY_TO=
SMTP_DESCRIPTION=default

# Application mailer (the server's own `Mailer` port — invitation emails, etc.)
# Separate from the SMTP_* block above, which configures Zitadel. The app
# server runs on the host, so MAIL_SMTP_HOST points at localhost (Mailpit's
# published port), not the `mailpit` docker hostname.
#   MAILER=log   structured log line only, no real send (default; CI/tests)
#   MAILER=smtp  send through MAIL_SMTP_* (Mailpit locally) — view at :8025
#   MAILER=ses   AWS SES (reads AWS_REGION + credentials from the AWS chain)
MAILER=smtp
MAIL_FROM=Effect Monorepo <noreply@localhost>
MAIL_SMTP_HOST=localhost
MAIL_SMTP_PORT=1025
MAIL_SMTP_SECURE=false
MAIL_SMTP_USER=
MAIL_SMTP_PASSWORD=

# Session cookie (server-issued, HttpOnly)
SESSION_COOKIE_NAME=session
# Generate via: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_COOKIE_SECRET=
SESSION_TTL_SECONDS=3600
SESSION_ABSOLUTE_TTL_SECONDS=43200
SESSION_TOUCH_THRESHOLD_SECONDS=60

# Stripe / Billing
# Required at server boot. Tests use `FakeBillingGatewayLive` and never
# call out to Stripe, so the placeholder values below are safe for `pnpm
# test`. Replace with real test-mode keys for the real-Stripe smoke flow
# (see README: `stripe listen --forward-to localhost:3001/webhooks/stripe`).
STRIPE_SECRET_KEY=sk_test_dummy_replace_for_real_stripe
STRIPE_WEBHOOK_SECRET=whsec_test_dummy_replace_for_real_stripe
# Single default price id for the MVP. A real product would resolve
# this from a plans catalog.
STRIPE_PRICE_ID_DEFAULT=price_test_dummy
